# app-earn environment — copy to `.env` and adjust for local dev.
# Only VITE_-prefixed vars are exposed to the client (via import.meta.env).
# There are NO secrets here; values are public URLs / addresses.

# Network ----------------------------------------------------------------------
# Selects the on-chain address profile (see src/lib/chain/config.ts).
#   devnet  (default) — the live devnet earn/staking deployment.
#   mainnet           — the mainnet earn/staking deployment.
# Unset / unknown → devnet (fail-safe default; existing builds unchanged).
VITE_NETWORK=devnet

# Optional RPC override. When unset, defaults to the public RPC for the network
# (api.devnet.solana.com / api.mainnet-beta.solana.com). Use a private endpoint
# (Helius / QuickNode) for production mainnet — the public RPC is rate-limited.
# VITE_RPC_URL=

# Meteora RWT/USDC DLMM pool (LB pair) address.
#   devnet  — defaults to the live devnet pool; override only if it is redeployed.
#   mainnet — REQUIRED at launch (C1). The pool does NOT exist on mainnet until
#             it is created at launch; set this to the new LB-pair address then.
#             While unset on mainnet the swap surface degrades gracefully
#             (market price shows "—", sell is unavailable).
# VITE_METEORA_POOL=

# Base URL of the backend faucet API (powers the devnet "Get test USDC" button).
# The faucet endpoint is devnet/localnet-only on the backend; on mainnet the
# affordance is hidden regardless of this value.
#
#   Production : https://api.areal.finance
#   Local dev  : http://localhost:3010   (NestJS dev port)
#
# Leave unset/empty to hide the faucet affordance entirely.
VITE_FAUCET_API_BASE=https://api.areal.finance
